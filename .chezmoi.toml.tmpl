{{- $role := "" -}}
{{- $distro := "" -}}

{{- /* Auto-detect from environment variable (used by sandbox containers) */ -}}
{{- if env "CHEZMOI_ROLE" -}}
{{-   $role = env "CHEZMOI_ROLE" -}}
{{-   if eq $role "arch" -}}
{{-     $distro = "arch" -}}
{{-   else if eq $role "fedora" -}}
{{-     $distro = "fedora" -}}
{{-   else if eq $role "macos" -}}
{{-     $distro = "macos" -}}
{{-   else if eq $role "container" -}}
{{-     $distro = "debian" -}}
{{-   end -}}
{{- /* Auto-detect macOS */ -}}
{{- else if eq .chezmoi.os "darwin" -}}
{{-   $role = "macos" -}}
{{-   $distro = "macos" -}}
{{- /* Prompt on Linux */ -}}
{{- else -}}
{{-   $role = promptStringOnce . "role" "Role (arch/container/fedora)" -}}
{{-   $distro = promptStringOnce . "distro" "Distro (arch/debian/fedora)" -}}
{{- end -}}

{{- if eq $role "container" -}}
{{-   $distro = "debian" -}}
{{- end -}}

encryption = "age"

[age]
  identity = "~/.config/chezmoi/key.txt"
  recipient = "age1v20cldj53evuwcufrcql25peam7rkcyr6zdhwmjrz8xlnx3gsdwq8rpjrz"

[data]
  role = {{ $role | quote }}
  distro = {{ $distro | quote }}
