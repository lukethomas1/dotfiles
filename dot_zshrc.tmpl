#
# ~/.zshrc — primary interactive shell config (managed by chezmoi).
#

# ---------------------------------------------------------------------------
# History (atuin takes over interactive search below, but keep a real histfile)
# ---------------------------------------------------------------------------
HISTFILE="${HOME}/.zsh_history"
HISTSIZE=100000
SAVEHIST=100000
setopt SHARE_HISTORY HIST_IGNORE_ALL_DUPS HIST_IGNORE_SPACE INC_APPEND_HISTORY

# ---------------------------------------------------------------------------
# Vi key bindings (fish: fish_vi_key_bindings)
# ---------------------------------------------------------------------------
bindkey -v
# fish bound ctrl-f to forward-char in insert/default/visual. In zsh,
# forward-char is registered as an autosuggestion "accept" widget, so this
# doubles as "accept suggestion" — matching the fish muscle memory.
bindkey -M viins '^F' forward-char
bindkey -M vicmd '^F' forward-char

# ---------------------------------------------------------------------------
# PATH (fish: fish_add_path $HOME/.local/bin)
# ---------------------------------------------------------------------------
typeset -U path                      # dedupe PATH entries
path=("$HOME/.local/bin" $path)
export PATH

# ---------------------------------------------------------------------------
# Homebrew / Linuxbrew — host only (no-op in containers or where brew absent).
# Needed on Fedora COSMIC Atomic / other immutable distros where CLI tools
# live under Linuxbrew. On macOS /opt/homebrew is already on PATH via the
# system, and this block is a no-op (path doesn't exist).
# ---------------------------------------------------------------------------
if [[ -x /home/linuxbrew/.linuxbrew/bin/brew && ! -f /run/.containerenv && ! -f /.dockerenv ]]; then
  eval "$(/home/linuxbrew/.linuxbrew/bin/brew shellenv)"
fi

# ---------------------------------------------------------------------------
# Plugins via antidote (self-cloning; see ~/.zsh_plugins.txt)
# ---------------------------------------------------------------------------
ANTIDOTE_DIR="${HOME}/.antidote"
if [[ ! -d "$ANTIDOTE_DIR" ]]; then
  git clone --depth=1 https://github.com/mattmc3/antidote "$ANTIDOTE_DIR" 2>/dev/null || true
fi
if [[ -f "$ANTIDOTE_DIR/antidote.zsh" ]]; then
  source "$ANTIDOTE_DIR/antidote.zsh"
  antidote load
fi

# Completion system (after antidote so zsh-completions' fpath is registered,
# and before carapace / the platform CLI completer which call compdef).
autoload -Uz compinit && compinit -d "${HOME}/.zcompdump"

# ---------------------------------------------------------------------------
# Abbreviations (fish: abbr --add ...). Defined as *session* abbreviations
# (-S) so they're recreated each shell like fish's config-driven abbrs and
# never written to zsh-abbr's persistent store. -q silences "already set".
# ---------------------------------------------------------------------------
if (( $+functions[abbr] )); then
  abbr -S -q k='kubectl'
  abbr -S -q pip='pip3'
  abbr -S --force -qq clear='clear -x'
  abbr -S --force -qq vim='nvim'
  abbr -S -q cd='z'
  abbr -S --force -qq cat='bat'
{{ if eq .distro "macos" -}}
  abbr -S -q timeout='gtimeout'
  abbr -S -q co='colima'
  abbr -S -q nerd='colima nerdctl'
  abbr -S -q key='ssh-add -k ~/.ssh/id_ed25519'
{{ end -}}

  # Git abbreviations
  abbr -S -q gco='git commit'
  abbr -S -q ga='git add'
  abbr -S -q gaa='git add .'
  abbr -S -q gs='git status'
  abbr -S -q gd='git diff'
  abbr -S -q gds='git diff --staged'
  abbr -S -q gp='git push'
  abbr -S -q gpl='git pull'
  abbr -S -q gl='git log --oneline'
  abbr -S -q gb='git branch'
  abbr -S -q gch='git checkout'
  abbr -S -q gcb='git checkout -b'
  abbr -S -q gst='git stash'
  abbr -S -q gsp='git stash pop'
  abbr -S -q grb='git rebase'

  # General dev
  abbr -S -q py='python3'
fi

{{ if eq .distro "arch" -}}
if command -v flatpak >/dev/null && flatpak info com.spotify.Client >/dev/null 2>&1; then
  alias spotify='flatpak run com.spotify.Client'
fi
{{ end -}}

# ---------------------------------------------------------------------------
# Environment variables
# ---------------------------------------------------------------------------
export GPG_TTY=$(tty)
export MAX_MCP_OUTPUT_TOKENS=3000
{{ if eq .distro "macos" -}}
export PKG_CONFIG_PATH="/opt/homebrew/opt/mysql-client/lib/pkgconfig:${PKG_CONFIG_PATH}"
{{ end -}}

# Source work-specific config if present (local only, not in dotfiles repo)
[[ -f ~/.config/work.zsh ]] && source ~/.config/work.zsh

{{ if eq .distro "arch" -}}
if [[ -o interactive ]]; then
  # Keychain chooses output syntax from $SHELL. The graphical session can
  # still export fish here, whose `set -x` syntax enables zsh xtrace when
  # evaluated. Force Bourne/zsh-compatible output instead.
  eval "$(SHELL=/usr/bin/zsh keychain --eval --quiet id_ed25519)"
fi
{{ end -}}

# ---------------------------------------------------------------------------
# Shell integrations
# ---------------------------------------------------------------------------
command -v atuin    >/dev/null && eval "$(atuin init zsh)"       # binds ctrl-r + up
command -v starship >/dev/null && eval "$(starship init zsh)"
command -v zoxide   >/dev/null && eval "$(zoxide init zsh)"
{{ if ne .role "container" -}}
export CARAPACE_BRIDGES='zsh,bash,inshellisense'
command -v carapace >/dev/null && source <(carapace _carapace zsh)
{{ end -}}
command -v fzf      >/dev/null && source <(fzf --zsh)

# ---------------------------------------------------------------------------
# ls → eza wrapper (fish: ~/.config/fish/functions/ls.fish)
# ---------------------------------------------------------------------------
ls() {
  if [[ " $* " == *" -h "* || " $* " == *" --help "* ]]; then
    eza --classify=never "$@"
  else
    eza --long --all --header --group-directories-first \
        --time-style=relative --git --icons --classify=never "$@"
  fi
}
