# Non-dotfile repo contents
README.md
NEW-MAC-SETUP.md
bootstrap.sh
pkg
pkg/**

# Container: full dev experience but no secrets or SSH
{{ if eq .role "container" }}
.ssh/**
.config/secrets.env
{{ end }}

# Shared ignores for non-container roles
{{ if ne .role "container" }}
.config/nvim/lua/plugins/disabled.lua
{{ end }}

# macOS: skip Linux-only stuff + SSH + secrets
{{ if eq .chezmoi.os "darwin" }}
.config/hypr/**
.bashrc
.zshrc
.ssh/**
.config/secrets.env
{{ end }}

# Arch: skip macOS-only stuff
{{ if eq .role "arch" }}
.config/aerospace/**
.zshrc
{{ end }}

# Fedora COSMIC Atomic: skip macOS-only + Arch-only stuff, use zsh instead of fish
{{ if eq .role "fedora" }}
.config/aerospace/**
.config/hypr/**
.config/fish/**
.bashrc
{{ end }}
