# Non-dotfile repo contents
README.md
NEW-MAC-SETUP.md
bootstrap.sh
pkg
pkg/**
archive
archive/**
assets
assets/**

# Container: full dev experience but no secrets or SSH
{{ if eq .role "container" }}
.ssh/**
.config/secrets.env
{{ end }}

# Shared ignores for non-container roles
{{ if ne .role "container" }}
.config/nvim/lua/plugins/disabled.lua
{{ end }}

# macOS: skip Linux-only stuff + SSH + secrets (zsh applies on all roles now)
{{ if eq .chezmoi.os "darwin" }}
.config/hypr/**
.bashrc
.ssh/**
.config/secrets.env
{{ end }}

# Arch: skip macOS-only desktop configuration. The former Hyprland
# configuration is retained under archive/ and is never deployed.
{{ if eq .role "arch" }}
.config/aerospace/**
{{ end }}

# Fedora COSMIC Atomic: skip macOS-only + Arch-only desktop configs
{{ if eq .role "fedora" }}
.config/aerospace/**
.config/hypr/**
.bashrc
{{ end }}
