// ────────────── Input Configuration ──────────────
// https://github.com/YaLTeR/niri/wiki/Configuration:-Input

input {
    keyboard {
        xkb {
            // Caps Lock is the sole Super/`Mod` key; it no longer toggles caps.
            // The physical Cmd/Super keys become Alt instead.
            options "caps:super,altwin:alt_win"
        }
        // Shorter initial delay and faster repeat for Backspace and all keys.
        repeat-delay 250
        repeat-rate 50
        numlock
    }

    touchpad {
        tap
        natural-scroll
    }

    mouse {
        // accel-profile "flat"
        // accel-speed 0.0
    }

    focus-follows-mouse
    workspace-auto-back-and-forth
}
