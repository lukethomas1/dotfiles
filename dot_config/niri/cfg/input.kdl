// ────────────── Input Configuration ──────────────
// https://github.com/YaLTeR/niri/wiki/Configuration:-Input

input {
    // Niri's Mod expands to XKB Mod3. Caps Lock is the only key mapped there,
    // keeping physical Cmd/Super and Alt available to applications.
    mod-key "Mod3"

    keyboard {
        xkb {
            // Caps Lock becomes Hyper (XKB Mod3) and no longer toggles caps.
            options "caps:hyper"
        }
        // Shorter initial delay and faster repeat for Backspace and all keys.
        repeat-delay 250
        repeat-rate 50
        numlock
    }

    touchpad {
        tap
        natural-scroll
    }

    mouse {
        // accel-profile "flat"
        // accel-speed 0.0
    }

    // Keep focus under explicit keyboard or click control; moving the pointer
    // near an off-screen column must not scroll the tiled view.
    // focus-follows-mouse
    workspace-auto-back-and-forth
}
